---
import "../styles/global.css";
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>

			<img src="dd1transparent.png"/>

			<section class="hero">
				<h1>Dipper Digital</h1>
				<p class="tagline">Independent game & web projects from Steven Lykins.</p>
			</section>

			<section class="projects">
				<div class="project-card stonk">
					<h2>stonkbattle</h2>
					<p>Stock market prediction game. Rank random securities, outsmart other players, and rise to the top of the leaderboard.</p>
					<a href="https://stonkbattle.com" target="_blank" rel="noopener noreferrer" class="project-link">stonkbattle.com →</a>
					<p>Made with Svelte</p>
				</div>

				<div class="project-card wyrd">
					<h2>WyrdRoot</h2>
					<small>(Closed Alpha Soon)</small>
					<p>A nature-themed massively multiplayer online browser game, with resource management and strategy elements.</p>
					<a href="https://wyrdroot.com" target="_blank" rel="noopener noreferrer" class="project-link">wyrdroot.com →</a>
					<p>Made with Laravel/Vue</p>
				</div>

				<div class="project-card astroprisma">
					<h2>Astroprisma Virtual Tabletop</h2>
					<p>A browser-based virtual tabletop for <a href="https://www.astroprisma.com/" target="_blank">Astroprisma, by Crescent Chimera</a></p>
					<a href="https://astroprismavue.dipper-digital.workers.dev/" target="_blank" rel="noopener noreferrer">Astroprisma →</a>
					<p>Made with Vue</p>
				</div>

				<div class="project-card fourad">
					<h2>Four Against Darkness</h2>
					<small>(In development)</small>
					<p>A browser-based virtual tabletop for <a href="https://www.ganeshagames.net/" target="_blank">Four Against Darkness by Andrea Sfiligoi.</a></p>
					<a href="#" target="_blank" rel="noopener noreferrer" class="project-link">Coming Soon?</a>
					<p>Made with React</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 3em 1em 2em;
	}
	.hero h1 {
		font-size: 3rem;
		margin-bottom: 0.4em;
	}
	.tagline {
		font-size: 1.2rem;
		color: rgb(var(--gray));
		margin: 0;
	}
	.projects {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2em;
		margin-top: 3em;
	}
	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
		padding: 2em;
		border-radius: 12px;
		border: 1px solid var(--border-color);
		background: var(--card-bg);
		box-shadow: var(--box-shadow);
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.project-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 30px rgba(var(--gray), 30%);
		color: inherit;
	}
	.project-card h2 {
		font-size: 1.6rem;
		margin: 0;
	}
	.project-card p {
		color: rgb(var(--gray));
		font-size: 1rem;
		margin: 0;
		flex: 1;
	}
	.project-link {
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--accent);
	}
	.stonk {
		border-top: 4px solid #2ecc71;
	}
	.wyrd {
		border-top: 4px solid #8e44ad;
	}
</style>
